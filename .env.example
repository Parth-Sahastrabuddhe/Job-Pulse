DISCORD_WEBHOOK_URL=
DISCORD_BOT_TOKEN=
DISCORD_CHANNEL_ID=
ADMIN_DISCORD_ID=
MULTI_USER_BOT_TOKEN=

AMAZON_URL=https://www.amazon.jobs/en/search?category%5B%5D=Software+Development&sort=recent&country%5B%5D=USA
MICROSOFT_URL=https://apply.careers.microsoft.com/careers?start=0&sort_by=Most+recent&filter_profession=software+engineering
JOB_TITLE_KEYWORDS=software engineer,software development engineer,sde,software developer
COUNTRY_FILTER=us

STATE_FILE=./data/state.json
DB_FILE=./data/jobs.db
SQLITE_BUSY_TIMEOUT_MS=8000
HEADLESS=true
DEBUG_BROWSER=false
PAGE_TIMEOUT_MS=45000
NETWORK_SETTLE_MS=4000
MAX_SCROLL_STEPS=5
MAX_LOAD_MORE_CLICKS=2
MAX_JOBS_PER_SOURCE=60
STATE_RETENTION_DAYS=45
POLL_INTERVAL_SECONDS=15
BATCH_SIZE=20
BATCH_DELAY_MS=15000
DB_BUSY_BACKOFF_MS=1000
SLOW_CYCLE_MINUTES=5
FAST_TRACK_COMPANIES=microsoft,amazon
FAST_TRACK_INTERVAL_SECONDS=60
SEEN_JOB_TOUCH_INTERVAL_MINUTES=360
SQLITE_UPSERT_CHUNK_SIZE=50
SQLITE_UPSERT_CHUNK_DELAY_MS=25
SHEET_SYNC_CHUNK_SIZE=100
SHEET_SYNC_CHUNK_DELAY_MS=50
SEEN_JOBS_CACHE_TTL_MINUTES=30
DM_LOG_FLUSH_INTERVAL_MS=5000
DM_LOG_FLUSH_MAX_SIZE=100
PLAYWRIGHT_MIN_MEM_MB=450
# Production default is night; set to always for local/manual full scrapes.
PLAYWRIGHT_SCHEDULE=night
PLAYWRIGHT_NIGHT_START=00:00
PLAYWRIGHT_NIGHT_END=06:00
PLAYWRIGHT_TIMEZONE=America/New_York
PLAYWRIGHT_NIGHT_RUN_INTERVAL_MINUTES=60
NIGHTLY_PLAYWRIGHT_SOURCES=uber,confluent
NIGHTLY_PLAYWRIGHT_MAX_POST_AGE_MINUTES=1440
MAX_POST_AGE_MINUTES=180
MAX_DATE_ONLY_AGE_DAYS=1
MAX_NEW_JOBS_PER_NOTIFY=25

# Heartbeat monitoring (healthchecks.io). Leave blank to disable.
HEARTBEAT_URL_MICRO=
HEARTBEAT_URL_MU=

# Multi-user Fit Check (feature toggle lives in the DB: /admin -> Features)
# Shared AES secret for per-user LLM keys. Generate: openssl rand -hex 32
# MUST match web/.env.local LLM_KEY_SECRET exactly. Loader is first-wins:
# check for an existing line before adding.
LLM_KEY_SECRET=
# Dashboard origin used in Discord nudge messages.
DASHBOARD_URL=http://3.138.62.29
# Per-user successful fit checks per UTC day.
MU_FIT_DAILY_CAP=25
