# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback
NEXT_PUBLIC_DISCORD_CLIENT_ID=

# Session
SESSION_SECRET=generate-a-random-32-char-string

# AWS SES
AWS_REGION=us-east-1
SES_FROM_EMAIL=noreply@jobpulse.app

# Admin
ADMIN_DISCORD_ID=your-discord-user-id

# Database
DB_PATH=../data/jobs.db

# Discord server auto-join + per-user channel provisioning
# (feature is skipped if any of these are missing)
# DISCORD_GUILD_ID: right-click server icon in Discord -> Copy Server ID
# DISCORD_BOT_ROLE_ID: "JobPulse Member" role assigned to verified users
# DISCORD_USER_FEED_CATEGORY_ID: category that holds each user's auto-created
#   private channel (e.g. "User Feeds"). Right-click category -> Copy ID.
# MULTI_USER_BOT_TOKEN: same bot token used by src/multi-user.js. The bot's
#   role must be Administrator (or have Manage Channels + Manage Roles + Create
#   Instant Invite + View Channel + Send Messages) and sit above DISCORD_BOT_ROLE_ID.
DISCORD_GUILD_ID=
DISCORD_BOT_ROLE_ID=
DISCORD_USER_FEED_CATEGORY_ID=
MULTI_USER_BOT_TOKEN=

# Fit Check: AES secret for per-user LLM keys.
# MUST match the root .env LLM_KEY_SECRET exactly (bot decrypts what web encrypts).
LLM_KEY_SECRET=
